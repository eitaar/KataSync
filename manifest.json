{
  "manifest_version": 3,
  "name": "KataSync",
  "version": "1.0.0",
  "description": "Sync your Codewars solutions to GitHub automatically",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.codewars.com/*",
    "https://api.github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "KataSync"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.codewars.com/kata/*/train/*",
        "https://www.codewars.com/kata/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}